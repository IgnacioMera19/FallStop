<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FallStop.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="fall_stop.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="Evitar riesgos de caidas" />

            <Label
                Text="FallStop"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Evitemos la caida de adultos mayores y evitemos riesgos y lesiones"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Evitemos la caida de adultos mayores y evitemos riesgos y lesiones" />

            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
