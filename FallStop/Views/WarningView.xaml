<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FallStop.Views.WarningView"
             BackgroundColor="#CC000000"
             Title="WarningView">
    
    <VerticalStackLayout VerticalOptions="Center"
                         HorizontalOptions="Center"
                         Spacing="20"
                         Padding="30">

        <Label Text="¡Posible caída detectada!"
               TextColor="White"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"/>

        <Label Text="Se enviará tu ubicación GPS a tu familiar."
               TextColor="White"
               FontSize="16"
               HorizontalTextAlignment="Center"/>

        <Label Text="¿Estás bien?"
               TextColor="White"
               FontSize="16"
               HorizontalTextAlignment="Center"/>

        <Button x:Name="CancelButton"
                Text="Cancelar envío (10)"
                BackgroundColor="#E53935"
                TextColor="White"
                FontSize="18"
                CornerRadius="10"
                Clicked="onCancelClicked"/>

    </VerticalStackLayout>
</ContentPage>